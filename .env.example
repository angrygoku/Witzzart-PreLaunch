# Environment Variables for WitzzartLaunch

# Node Environment
NODE_ENV=production

# Database Configuration (if using external database)
# DATABASE_URL=your_database_connection_string_here

# Optional: For production deployment
# PORT=5000

# Note: The current implementation uses in-memory storage for simplicity
# For production, consider using:
# - Netlify Identity for user management
# - FaunaDB, PlanetScale, or Supabase for database
# - Form submission services like Netlify Forms or Formspree