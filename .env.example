# Environment Variables for WitzzartLaunch

# Node Environment
NODE_ENV=production

# Database Configuration (if using external database)
# DATABASE_URL=your_database_connection_string_here

# Optional: For production deployment
# PORT=5000

# Waitlist email notification via Resend
# RESEND_API_KEY=re_xxxxxxxxx
# RESEND_FROM_EMAIL=Witzzart <waitlist@yourdomain.com>
# WAITLIST_NOTIFY_EMAIL_TO=govinddixit@witzzart.com

# Waitlist WhatsApp notification via Twilio
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# WAITLIST_NOTIFY_WHATSAPP_TO=whatsapp:+919675624255

# Notes:
# - Secrets should be set in your deployment provider, not committed.
# - Twilio WhatsApp requires an approved WhatsApp sender.
# - Free-form outbound WhatsApp messages are subject to WhatsApp session rules.
# - The current signup storage is still in-memory; add a real database for persistence.
